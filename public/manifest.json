{
  "manifest_version": 3,
  "name": "Browser Assistant",
  "version": "0.1.0",
  "description": "An AI-powered browser assistant.",
  "permissions": [
  "tabs",
  "activeTab"
],
  "action": {
    "default_popup": "index.html",
    "default_title": "Browser Assistant"
  },
  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }
]
}